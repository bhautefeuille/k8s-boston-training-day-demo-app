{
  "name": "Ubuntu Kubernetes Lab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "hostRequirements": {
    "cpus": 8,
    "memory": "32gb"
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "onCreateCommand": {
    "pull-base-images": "docker pull docker.io/mcp/grafana:latest",
    "pull-test-images": "docker pull testcontainers/ryuk:0.7.0 && docker pull localstack/localstack:3",
    "pull odigos-demo-images": "registry.odigos.io/odigos-demo-pricing:v0.1.35 &&  registry.odigos.io/odigos-demo-membership:v0.1.35 && registry.odigos.io/odigos-demo-load-generator:v0.1.35 && registry.odigos.io/odigos-demo-coupon:v0.1.35",
    "pull odigos-demo-images2": "registry.odigos.io/odigos-demo-currency:v0.1.35 && registry.odigos.io/odigos-demo-frontend:v0.1.35 && registry.odigos.io/odigos-demo-geolocation:v0.1.35 && registry.odigos.io/odigos-demo-inventory:v0.1.35 "


  },

  "customizations": {
    "vscode": {
      "extensions": [
        "stateful.runme",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "redhat.vscode-yaml"
      ]
    }
  },

  "forwardPorts": [30080, 30081, 8080],

  "postCreateCommand": "echo 'Codespace ready'",
  "postAttachCommand": "code /workspaces/k8s-boston-training-day-demo-app/content/0-Gemini-api-key/gemini-api-key.md"
}
